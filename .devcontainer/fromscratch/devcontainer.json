{
    "name": "sal (Build From Scratch)",
    "dockerFile": "Dockerfile",
    "context": "..",
    "remoteUser": "lean",
    "workspaceFolder": "/workspace",
    "customizations": {
        "vscode": {
            "extensions": [
                "leanprover.lean4"
            ],
            "settings": {
                "lean4.executablePath": "lake",
                "lean4.serverArgs": [],
                "editor.formatOnSave": true,
                "[lean]": {
                    "editor.defaultFormatter": "leanprover.lean4",
                    "editor.formatOnSave": true,
                    "editor.tabSize": 2,
                    "editor.insertSpaces": true
                },
                "files.exclude": {
                    "**/.lake": true,
                    "**/*.olean": true
                }
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {
            "ppa": true
        }
    },
    "postCreateCommand": "lean --version && echo 'Lean environment ready'",
    "postStartCommand": "",
    "updateContentCommand": "",
    "forwardPorts": [],
    "remoteEnv": {
        "LEAN_PATH": "/home/lean/.elan/toolchains/leanprover--lean4---v4.28.0/lib/lean/library"
    }
}
